# GEMINI_API_KEY: Recommended for AI Studio / environments with backend (Express).
# This keeps the key hidden from the browser.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: Fallback for static deployments (Netlify/Vercel) without backend.
# Note: This will be visible in the browser's network tab.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
